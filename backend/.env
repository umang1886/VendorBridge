SECRET_KEY=change-this-to-a-strong-secret-key
JWT_SECRET_KEY=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Supabase PostgreSQL Direct Connection
# Get from: Supabase → Settings → Database → Connection String (URI)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ── Email ─────────────────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
FROM_EMAIL=VendorBridge <noreply@yourdomain.com>

# ── AI ────────────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY

# ── n8n Automation ────────────────────────────────────────────────────────────
# URL where your n8n instance is running
N8N_WEBHOOK_BASE_URL=http://localhost:5678

# ── Celery/Redis ─────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
